{
  "name": "Aperio",
  "version": "0.66.0",
  "description": "Personal AI memory layer — Postgres + MCP + Claude",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "mcp": "node mcp/index.js",
    "start": "node server.js",
    "start:cloud": "PORT=1701 node server.js",
    "start:local": "AI_PROVIDER=ollama PORT=31337 node server.js",
    "start:lite": "AI_PROVIDER=ollama PORT=31337 DB_BACKEND=sqlite EMBEDDING_PROVIDER=transformers node server.js",
    "chat": "node lib/terminal.js",
    "chat:cloud": "PORT=1701 node lib/terminal.js",
    "chat:local": "AI_PROVIDER=ollama PORT=31337 node lib/terminal.js",
    "test:skills": "NODE_ENV=test node --test tests/skills/skills.test.js",
    "test:execution": "NODE_ENV=test node --test tests/skills/execution.test.js",
    "test:store": "NODE_ENV=test node --test tests/store/store.test.js",
    "test:backfill": "NODE_ENV=test node --test tests/store/backfill.test.js",
    "test:memory": "NODE_ENV=test node --test tests/tools/memory.test.js",
    "test:only": "NODE_ENV=test node --test --test-name-pattern",
    "test": "NODE_ENV=test node --test $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) 'tests/**/*.test.js'",
    "test:e2e": "NODE_ENV=test node --test 'tests/e2e/**/*.test.js'",
    "test:ci": "NODE_ENV=test node --test $([ -z \"$APERIO_AGENT_RUN\" ] && echo --experimental-test-coverage) $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) 'tests/**/*.test.js'",
    "gen:env": "node scripts/gen-env-example.js",
    "gen:env:check": "node scripts/gen-env-example.js --check",
    "config:sync": "node scripts/config-sync.js",
    "migrate": "node db/migrate.js",
    "migrate:sqlite": "node -e \"import('./db/sqlite.js').then(m => m.SqliteStore.init().then(s => s.close()))\"",
    "coverage": "c8 report --reporter=lcov --reporter=text"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "emphasize": "^7.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fast-xml-parser": "^5.9.3",
    "gpt-tokenizer": "^3.4.0",
    "helmet": "^8.2.0",
    "mammoth": "^1.12.0",
    "mssql": "^12.6.0",
    "mysql2": "^3.22.5",
    "ollama": "^0.6.3",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "pptxgenjs": "^4.0.1",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^14.0.1",
    "web-tree-sitter": "^0.26.10",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  },
  "overrides": {
    "@huggingface/transformers": {
      "sharp": "$sharp"
    }
  }
}
