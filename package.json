{
  "name": "Aperio",
  "version": "0.67.5",
  "description": "Personal AI memory layer — Postgres + MCP + Claude",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "mcp": "node mcp/index.js",
    "start": "node server.js",
    "start:cloud": "PORT=1701 node server.js",
    "start:local": "AI_PROVIDER=llamacpp PORT=31337 node server.js",
    "start:lite": "AI_PROVIDER=llamacpp PORT=31337 DB_BACKEND=sqlite EMBEDDING_PROVIDER=transformers IDLE_SHUTDOWN=on APERIO_LITE=on APERIO_CONFIG_PRECEDENCE=db node server.js",
    "chat": "node lib/terminal.js",
    "chat:cloud": "PORT=1701 node lib/terminal.js",
    "chat:local": "AI_PROVIDER=llamacpp PORT=31337 node lib/terminal.js",
    "local:bench": "node scripts/local-bench.js",
    "prompt-cache:bench": "node scripts/prompt-cache-bench.js",
    "model-tier:pilot": "node scripts/model-tier-bench.js",
    "test:skills": "NODE_ENV=test node --test tests/integration/skills/skills.test.js",
    "test:execution": "NODE_ENV=test node --test tests/integration/skills/execution.test.js",
    "test:store": "NODE_ENV=test node --test tests/integration/store/store.test.js",
    "test:backfill": "NODE_ENV=test node --test tests/integration/store/backfill.test.js",
    "test:memory": "NODE_ENV=test node --test tests/unit/tools/memory.test.js",
    "test:only": "NODE_ENV=test node --test --test-name-pattern",
    "test": "NODE_ENV=test node --test $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) $(find tests/unit tests/integration tests/e2e -name '*.test.js' -print)",
    "test:unit": "NODE_ENV=test node --test $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) $(find tests/unit -name '*.test.js' -print)",
    "test:integration": "NODE_ENV=test node --test --test-concurrency=1 $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) $(find tests/integration -name '*.test.js' -print)",
    "test:e2e": "NODE_ENV=test node --test --test-concurrency=2 'tests/e2e/**/*.test.js'",
    "test:e2e:real": "NODE_ENV=test node --test --test-concurrency=2 'tests/e2e/real-app/real-app-*.test.js'",
    "test:e2e:ci": "NODE_ENV=test node --test --test-concurrency=2 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporters/e2e-json.js --test-reporter-destination=e2e-results.json $(find tests/e2e -name '*.test.js' -not -name 'real-app-*.test.js' -print)",
    "test:e2e:ci:dashboard": "npm run test:e2e:ci && npm run e2e:dashboard -- --exclude-real-app",
    "test:integration:ci": "NODE_ENV=test node --test --test-concurrency=1 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporters/integration-json.js --test-reporter-destination=integration-results.json $(find tests/integration -name '*.test.js' -print)",
    "test:integration:ci:dashboard": "npm run test:integration:ci && npm run integration:dashboard",
    "test:ci": "NODE_ENV=test c8 --clean node --test $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) $(find tests/unit tests/integration -name '*.test.js' -print)",
    "test:ci:unit": "NODE_ENV=test node --test --test-concurrency=1 --test-reporter=$([ -n \"$APERIO_AGENT_RUN\" ] && echo ./tests/reporters/quiet.js || echo spec) --test-reporter-destination=stdout --test-reporter=./tests/reporters/unit-json.js --test-reporter-destination=unit-results.json $(find tests/unit -name '*.test.js' -print)",
    "test:ci:integration": "NODE_ENV=test c8 --clean node --test --test-concurrency=1 $([ -n \"$APERIO_AGENT_RUN\" ] && echo --test-reporter=./tests/reporters/quiet.js --test-reporter-destination=stdout) $(find tests/integration -name '*.test.js' -print)",
    "test:ci:dashboard": "NODE_ENV=test c8 --clean node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporters/e2e-json.js --test-reporter-destination=e2e-results.json 'tests/**/*.test.js'",
    "gen:env": "node scripts/gen-env-example.js",
    "gen:env:check": "node scripts/gen-env-example.js --check",
    "i18n:check": "node scripts/diff-locales.js && node scripts/check-docs-i18n.js",
    "config:sync": "node scripts/config-sync.js",
    "migrate": "node db/migrate.js",
    "migrate:sqlite": "node -e \"import('./db/sqlite.js').then(m => m.SqliteStore.init().then(s => s.close()))\"",
    "vmtest:linux": "bash vms/run-vagrant.sh ubuntu-lite",
    "vmtest:linux:debian": "bash vms/run-vagrant.sh debian-dev",
    "vmtest:mac": "bash vms/mac/run.sh",
    "vmtest:docker": "bash vms/docker/run.sh",
    "vmtest:windows": "bash vms/win/run.sh",
    "coverage": "c8 report --reporter=lcov --reporter=text",
    "coverage:dashboard": "node scripts/generate-coverage-dashboard.js",
    "e2e:dashboard": "node scripts/generate-e2e-dashboard.js",
    "integration:dashboard": "node scripts/generate-integration-dashboard.js",
    "unit:dashboard": "node scripts/generate-unit-dashboard.js",
    "test:unit:dashboard": "NODE_ENV=test node --test --test-concurrency=1 $(find tests/unit -name '*.test.js' -print) 2>&1 | tail -1 && node trash/temp/make-unit-results.mjs && npm run unit:dashboard",
    "test:e2e:dashboard": "NODE_ENV=test node --test --test-concurrency=2 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporters/e2e-json.js --test-reporter-destination=e2e-results.json 'tests/e2e/**/*.test.js' && npm run e2e:dashboard"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@anthropic-ai/sdk": "^0.112.3",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "adm-zip": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "emphasize": "^7.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "fast-xml-parser": "^5.10.0",
    "gpt-tokenizer": "^3.4.0",
    "helmet": "^8.3.0",
    "mammoth": "^1.12.0",
    "mssql": "^12.7.0",
    "mysql2": "^3.23.1",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.22.0",
    "pptxgenjs": "^4.0.1",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.35.3",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^14.0.1",
    "web-tree-sitter": "^0.24.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "c8": "^12.0.0"
  },
  "overrides": {
    "@huggingface/transformers": {
      "sharp": "$sharp"
    }
  }
}
