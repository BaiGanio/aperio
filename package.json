{
  "name": "aperio",
  "version": "2.43.6",
  "description": "Personal AI memory layer — Postgres + MCP + Claude",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "mcp": "node mcp/index.js",
    "start": "node server.js",
    "start:cloud": "AI_PROVIDER=anthropic PORT=3000 node server.js",
    "start:local": "AI_PROVIDER=ollama PORT=31337 node server.js",
    "start:lite": "AI_PROVIDER=ollama PORT=31337 DB_BACKEND=lancedb CHECK_RAM=false node server.js",
    "chat": "node lib/chat.js",
    "chat:cloud": "AI_PROVIDER=anthropic PORT=3000 node lib/chat.js",
    "chat:local": "AI_PROVIDER=ollama PORT=31338 node lib/chat.js",
    "test:skills": "node --test tests/skills/skills.test.js",
    "test:execution": "node --test tests/skills/execution.test.js",
    "test:store": "node --test tests/store/store.test.js",
    "test:backfill": "node --test tests/store/backfill.test.js",
    "test:memory": "node --test tests/tools/memory.test.js",
    "test:only": "node --test --test-name-pattern",
    "test": "node --test 'tests/**/*.test.js'",
    "test:ci": "c8 node --test 'tests/**/*.test.js'",
    "coverage": "c8 report --reporter=lcov --reporter=text"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ollama": "^0.6.3",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
