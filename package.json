{
  "name": "aperio",
  "version": "2.16.8",
  "description": "Personal AI memory layer — Postgres + MCP + Claude",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "node --test tests/mcp-tools.test.js",
    "start": "node server.js",
    "start:cloud": "AI_PROVIDER=anthropic PORT=3000 node server.js",
    "start:local": "AI_PROVIDER=ollama PORT=31337 node server.js",
    "chat": "node scripts/chat.js",
    "chat:cloud": "AI_PROVIDER=anthropic PORT=3000 node scripts/chat.js",
    "chat:local": "AI_PROVIDER=ollama PORT=31338 node scripts/chat.js",
    "start:lite": "AI_PROVIDER=ollama PORT=31337 DB_BACKEND=lancedb CHECK_RAM=false node server.js",
    "mcp": "node mcp/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@lancedb/lancedb": "^0.27.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "ollama": "^0.6.3",
    "pg": "^8.11.0",
    "uuid": "^13.0.0",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  }
}
