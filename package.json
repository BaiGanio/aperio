{
  "name": "Aperio",
  "version": "0.54.0",
  "description": "Personal AI memory layer — Postgres + MCP + Claude",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "mcp": "node mcp/index.js",
    "start": "node server.js",
    "start:cloud": "PORT=1701 node server.js",
    "start:local": "AI_PROVIDER=ollama PORT=31337 node server.js",
    "start:lite": "AI_PROVIDER=ollama PORT=31337 DB_BACKEND=sqlite EMBEDDING_PROVIDER=transformers node server.js",
    "chat": "node lib/terminal.js",
    "chat:cloud": "PORT=1701 node lib/terminal.js",
    "chat:local": "AI_PROVIDER=ollama PORT=31337 node lib/terminal.js",
    "test:skills": "NODE_ENV=test node --test tests/skills/skills.test.js",
    "test:execution": "NODE_ENV=test node --test tests/skills/execution.test.js",
    "test:store": "NODE_ENV=test node --test tests/store/store.test.js",
    "test:backfill": "NODE_ENV=test node --test tests/store/backfill.test.js",
    "test:memory": "NODE_ENV=test node --test tests/tools/memory.test.js",
    "test:only": "NODE_ENV=test node --test --test-name-pattern",
    "test": "NODE_ENV=test node --test 'tests/**/*.test.js'",
    "test:e2e": "NODE_ENV=test node --test 'tests/e2e/**/*.test.js'",
    "test:ci": "NODE_ENV=test node --test --experimental-test-coverage 'tests/**/*.test.js'",
    "migrate": "node db/migrate.js",
    "migrate:sqlite": "node -e \"import('./db/sqlite.js').then(m => m.SqliteStore.init().then(s => s.close()))\"",
    "coverage": "c8 report --reporter=lcov --reporter=text"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@anthropic-ai/sdk": "^0.93.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^3.3.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "docx": "^9.7.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.2",
    "gpt-tokenizer": "^3.4.0",
    "mammoth": "^1.12.0",
    "ollama": "^0.6.3",
    "open": "^11.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.9",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^14.0.0",
    "web-tree-sitter": "^0.22.6",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
