# OpenBrain Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openbrain
POSTGRES_USER=openbrain
POSTGRES_PASSWORD=openbrain_secret   # change this!

# Connection string (used by MCP server)
DATABASE_URL=postgresql://openbrain:openbrain_secret@localhost:5432/openbrain

# Claude API (used in Step 4)
ANTHROPIC_API_KEY=your_key_here
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx
