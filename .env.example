# Aperio Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret      # change this!

# Connection string (used by MCP server + server.js)
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio

# ── AI APIs ───────────────────────────────────────────────────
# Anthropic — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Voyage AI — free tier at dash.voyageai.com (50M tokens/month)
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────
PORT=3000