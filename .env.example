# ============================================================
# Aperio — configuration bootstrap
# AUTO-GENERATED from lib/config.js — run `npm run gen:env` to regenerate;
# edit the registry, not this file. NEVER commit a real .env to git.
#
# Only what belongs in .env lives here: the START-HERE provider block and
# the bootstrap/security keys read before the database opens. Everything
# else is set in the app's Settings — full reference: docs/config-reference.md
# Copy to `.env` and edit — or just run `npm start` and take it from there.
# ============================================================

# ── ESSENTIALS ────────────────────────────────────────────────
# Which AI backend to use.
# options: anthropic | deepseek | gemini | llamacpp | claude-code | codex
AI_PROVIDER=llamacpp
# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# DeepSeek — platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# Google Gemini — aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Port the web app runs on.
PORT=31337

# ╶───────────────────────────────────────────────────────────╴
#  Everything else is configured in the app's Settings (saved to the
#  database). Any variable from docs/config-reference.md still works
#  here — set APERIO_CONFIG_PRECEDENCE=env to make this file win.
# ╶───────────────────────────────────────────────────────────╴
# APERIO_CONFIG_PRECEDENCE=env

# ── Database (bootstrap) ──────────────────────────────────────
# DB_BACKEND=sqlite
# SQLITE_PATH=./.sqlite/aperio.db
# APERIO_DB_ENCRYPT=1

# ── Postgres ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:8008/aperio

# ── Server ────────────────────────────────────────────────────
# HOST=0.0.0.0

# ── Network security ──────────────────────────────────────────
# APERIO_ALLOWED_HOSTS=aperio.lan,192.168.1.50
# APERIO_CSP=on
# APERIO_AUTH_TOKEN=
# APERIO_ALLOW_DEFAULT_DB_PASSWORD=1

# ── Hosting hardening ─────────────────────────────────────────
# APERIO_TLS_CERT=/path/to/cert.pem
# APERIO_TLS_KEY=/path/to/key.pem
# APERIO_SESSION_KEY=
