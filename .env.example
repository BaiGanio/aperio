# ============================================================
# Ensure the main script is executable
# chmod +x ./START.sh

# Launch the main logic
# ./START.sh

# @echo off
# powershell -NoProfile -ExecutionPolicy Bypass -File "./script.ps1"
# pause
# ============================================================

# ============================================================
# Aperio — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── VECTOR STORE BACKEND ──────────────────────────────────────────────────
# ------------------------------------------------------------
# Options : 'postgres' | 'lancedb'
# Default : auto-detect (uses Postgres if Docker is running, else LanceDB)
# ------------------------------------------------------------
# DB_BACKEND=lancedb

# ------------------------------------------------------------
# LanceDB (non-technical users / no Docker)
# Optional — defaults to ./.lancedb in the project root
# ------------------------------------------------------------
# LANCEDB_PATH=./.lancedb

# ── DATABASE ──────────────────────────────────────────────────
# ------------------------------------------------------------
# Postgres (power users / Docker)
# Required only when DB_BACKEND=postgres or Docker is detected
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret      # change this!
# ------------------------------------------------------------
# Connection string (used by MCP server + server.js)
# ------------------------------------------------------------
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio

# ------------------------------------------------------------
# Restrict file READ operations to specific directories (comma-separated).
# Defaults to the current working directory if not set.
# ------------------------------------------------------------
APERIO_ALLOWED_PATHS_TO_READ=/Users/ME/Projects/BaiGanio/aperio
# ------------------------------------------------------------
# Restrict file WRITE operations to specific directories (comma-separated).
# Defaults to the current working directory if not set.
# This should typically be equal to or a strict subset of READ paths.
# ------------------------------------------------------------
APERIO_ALLOWED_PATHS_TO_WRITE=/Users/ME/Projects/BaiGanio/aperio

# ── AI Provider ───────────────────────────────────────────────
# ------------------------------------------------------------
# Controls which AI backend Aperio uses.
# Override at startup: npm run start:cloud / npm run start:local
# If not set, defaults to "anthropic"
# ------------------------------------------------------------
#AI_PROVIDER=anthropic                # "anthropic" | "ollama" | "deepseek"
AI_PROVIDER=ollama

# ── AI APIs ───────────────────────────────────────────────────
# ------------------------------------------------------------
# Anthropic — get yours at console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxx-xxxx
# ------------------------------------------------------------
# Other options: claude-sonnet-4-6, claude-opus-4-6
# ------------------------------------------------------------
ANTHROPIC_MODEL=claude-haiku-4-5-202510012

# ── DeepSeek (cloud) ──────────────────────────────────────────
# ------------------------------------------------------------
# Sign up at platform.deepseek.com
# deepseek-chat   — V3, full tool + memory support (recommended)
# deepseek-reasoner — R1, shows reasoning, no tool calls
# Embeddings: DeepSeek has no embedding API.
# Keep EMBEDDING_PROVIDER=transformers or =voyage when using DeepSeek.
# ------------------------------------------------------------
# AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_MODEL=deepseek-chat

# ── Ollama (local) ────────────────────────────────────────────
# ------------------------------------------------------------
# Install Ollama at ollama.ai, then: ollama pull qwen2.5:3b
# ------------------------------------------------------------
OLLAMA_MODEL=qwen2.5:3b
#OLLAMA_MODEL=llama3.1
#OLLAMA_MODEL=qwen3:4b
#OLLAMA_MODEL=qwen3:14b
#OLLAMA_MODEL=gemma4:26b
#OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings ────────────────────────────────────────────────
# ------------------------------------------------------------
# Options: 'transformers' | 'voyage'
# Default: 'transformers' (no external service required)
# ------------------------------------------------------------

# Option 1 — HuggingFace Transformers (default, fully local)
# Downloads mixedbread-ai/mxbai-embed-large-v1 (ONNX, q8) on first run.
# No daemon, no API key. Used by start:lite automatically.
EMBEDDING_PROVIDER=transformers

# Option 2 — Voyage AI (cloud, free tier: 50M tokens/month)
# Sign up at dash.voyageai.com
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-xxxxx-xxxx

# ── Server ────────────────────────────────────────────────────
PORT=31337