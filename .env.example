# ============================================================
# Aperio — Configuration
#
# AUTO-GENERATED from lib/config.js — do not edit by hand.
# Run `npm run gen:env` to regenerate. Edit the registry, not this file.
#
# This template is deliberately tiny: it holds only bootstrap plumbing plus
# the essential provider choices. EVERY OTHER setting is a typed control in
# the app — open the sidebar's Configuration panel — and is stored in the
# database, not here. Most people never touch this file at all: run
# `npm start` and the setup wizard in your browser writes a real `.env`.
#
# To configure by hand: copy this file to `.env` and set the ESSENTIALS
# block below. Everything past the STOP line is bootstrap/security plumbing
# that must live in `.env`; it already has sensible defaults.
#
# Developers: you can still add ANY variable here by hand (see the full list
# in the Configuration panel or `npm run config:sync`). A value saved in the
# UI is stored in the DB and overrides `.env` (precedence: DB > .env >
# default).
#
# NEVER commit .env to git.
# ============================================================

# ── ESSENTIALS ────────────────────────────────────────────────
# The few values most setups need to get started.

# Which AI backend to use.
# • anthropic / deepseek / gemini → cloud; paste the matching API key below.
# • ollama → free, runs on your machine (no key).
# • claude-code → uses your Claude Pro/Max subscription via the Agent SDK (requires the `claude` CLI logged in; do NOT also set ANTHROPIC_API_KEY).

AI_PROVIDER=ollama          # options: anthropic | deepseek | gemini | ollama | claude-code

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Alternative to running `claude` interactively when AI_PROVIDER=claude-code.
# CLAUDE_CODE_OAUTH_TOKEN=

# DeepSeek — platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# LOCAL: if you chose ollama, set the model (install: ollama.ai).
# Pick by RAM: 8GB → qwen3:4b · 16GB → llama3.1:8b · 32GB+ → qwen3:14b
OLLAMA_MODEL=qwen3:4b

# OpenAI key (only if you wire an OpenAI-compatible provider).
# OPENAI_API_KEY=

# Port the web app runs on.
PORT=31337

# ╶───────────────────────────────────────────────────────────╴
#  ✋  YOU CAN STOP HERE.
#      Everything below is bootstrap/security plumbing that must live
#      in .env. Every other setting lives in the app's Configuration
#      panel (saved to the database). Only change the lines below if
#      you know you need to.
# ╶───────────────────────────────────────────────────────────╴

# ── Database (bootstrap) ──────────────────────────────────────
# How and where Aperio stores its data. Read at startup before anything else, so these stay in .env.

# 'postgres' (Docker required) | 'sqlite' (zero-config, default).
# Default: auto-detect — Postgres if Docker is running, else SQLite.
# options: sqlite | postgres
# DB_BACKEND=sqlite

# Where SQLite stores data (default shown).
# SQLITE_PATH=./sqlite/aperio.db

# Encrypt the SQLite database file on disk with AES-256-GCM. Key lives in your OS keychain. Off by default; SQLite only.
# APERIO_DB_ENCRYPT=1

# ── Postgres ──────────────────────────────────────────────────
# Only used when DB_BACKEND=postgres (or Docker is detected).

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret   # Change this!
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio

# ── Server ────────────────────────────────────────────────────

# Default 127.0.0.1 (loopback only — safe). Set 0.0.0.0 for LAN access only if you understand the risks.
# HOST=0.0.0.0

# ── Network security ──────────────────────────────────────────

# Extra hostnames accepted by the Host-header / DNS-rebinding guard (comma-separated). Add these if you reach Aperio via a reverse proxy or LAN name.
# APERIO_ALLOWED_HOSTS=aperio.lan,192.168.1.50

# Opt-in shared-secret auth. When set, every /api request and WebSocket must present it (Authorization: Bearer, X-Aperio-Token, or ?token=). Set a long random value before exposing Aperio on a network.
# APERIO_AUTH_TOKEN=

# Advanced: bypass the startup refusal to run Postgres with the shipped default password. Do NOT set in production.
# APERIO_ALLOW_DEFAULT_DB_PASSWORD=1

# ── Hosting hardening ─────────────────────────────────────────

# Opt-in TLS. Set BOTH cert + key (PEM) to serve HTTPS; leave both unset for plain HTTP on loopback. Aperio does not generate certs.
# APERIO_TLS_CERT=/path/to/cert.pem

# TLS private key (PEM). See APERIO_TLS_CERT.
# APERIO_TLS_KEY=/path/to/key.pem

# Opt-in at-rest session encryption (AES-256-GCM). When set, session transcripts are encrypted on disk; existing plaintext still loads.
# APERIO_SESSION_KEY=
