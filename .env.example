# Aperio Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret      # change this!

# Connection string (used by MCP server + server.js)
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio

# ── Restrict file operations to specific directories (comma-separated)
# Defaults to your home directory if not set
# APERIO_ALLOWED_PATHS=/Users/yourname/projects,/Users/yourname/documents

# ── AI Provider ───────────────────────────────────────────────
# Controls which AI backend Aperio uses.
# Override at startup: npm run start:cloud / npm run start:local
# If not set, defaults to "Ollama"
# AI_PROVIDER=anthropic
AI_PROVIDER=ollama

# ── Anthropic (cloud) ─────────────────────────────────────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Other options: claude-sonnet-4-6, claude-opus-4-6

# ── Ollama (local) ────────────────────────────────────────────
# Install Ollama at ollama.ai, then: ollama pull llama3.1
OLLAMA_MODEL=llama3.1
#OLLAMA_MODEL=deepseek-r1:14b
#OLLAMA_MODEL=deepseek-r1:7b
#OLLAMA_MODEL=qwen3
OLLAMA_BASE_URL=http://localhost:11434
# Other options: mistral, qwen2.5, gemma2, phi3, etc.

# ── Embeddings (default Ollama) ────────────────────────────────────────────
# ollama pull mxbai-embed-large
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
# Comment above two lines and uncomment below to use Voyage AI — free tier at dash.voyageai.com (50M tokens/month)
# VOYAGE_API_KEY=pa-xxxxxx

# ── Server ────────────────────────────────────────────────────
PORT=3000
