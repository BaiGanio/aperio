# ============================================================
# Aperio — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── VECTOR STORE BACKEND ──────────────────────────────────────────────────
# ------------------------------------------------------------
# Options : 'postgres' | 'lancedb'
# - Postgres (power users / Docker)
# - LanceDB (non-technical users / no Docker)
# Default : auto-detect (uses Postgres if Docker is running, else LanceDB)
# ------------------------------------------------------------
# DB_BACKEND=lancedb
# ------------------------------------------------------------
# Optional — defaults to ./.lancedb in the project root
# ------------------------------------------------------------
# LANCEDB_PATH=./.lancedb

# ── DATABASE ──────────────────────────────────────────────────
# ------------------------------------------------------------
# Required only when DB_BACKEND=postgres or Docker is detected
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret      # change this!
# ------------------------------------------------------------
# Connection string (used by MCP server + server.js)
# ------------------------------------------------------------
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio
# ── DATABASE ──────────────────────────────────────────────────
# ── VECTOR STORE BACKEND ──────────────────────────────────────────────────

# ── Path Safety ───────────────────────────────────────────────
# ------------------------------------------------------------
# Restrict file READ operations to specific directories (comma-separated).
# Defaults to the current working directory if not set.
# ------------------------------------------------------------
# Restrict file WRITE operations to specific directories (comma-separated).
# Defaults to the current working directory if not set.
# This should typically be equal to or a strict subset of READ paths.
# ------------------------------------------------------------
APERIO_ALLOWED_PATHS_TO_READ=/Users/CHANGE-ME/Projects/BaiGanio/aperio
APERIO_ALLOWED_PATHS_TO_WRITE=/Users/CHANGE-ME/Projects/BaiGanio/aperio
# ------------------------------------------------------------
# ── Path Safety ───────────────────────────────────────────────

# ── AI Provider ───────────────────────────────────────────────
# ------------------------------------------------------------
# Controls which AI backend Aperio uses.
# Override at startup: npm run start:cloud / npm run start:local
# If not set, defaults to "ollama"
# ------------------------------------------------------------
#AI_PROVIDER=anthropic    # "anthropic" | "ollama" | "deepseek" | "gemini"
AI_PROVIDER=ollama

# ── Round-table mode (two-agent cross-review) ─────────────────
# ------------------------------------------------------------
# When set, Aperio boots a SECOND agent (the "verifier") alongside the primary.
# The Discuss toggle in the chat UI then routes a turn through a round-table
# protocol: A answers → B reviews → A revises → B re-reviews → … until both
# AGREE or the round cap is hit.
#
# Format: <provider>:<model>,<provider>:<model>
#   - First pair  → primary  (the answerer, "Agent A")
#   - Second pair → verifier (the reviewer, "Agent B")
# Supported providers: anthropic | ollama | deepseek | gemini
# ------------------------------------------------------------
# ROUNDTABLE_AGENTS=anthropic:claude-haiku-4-5-20251001,deepseek:deepseek-v4-flash
# ROUNDTABLE_MAX_ROUNDS=3

# ── Wiki refresh provider (stale-article self-heal) ───────────
# ------------------------------------------------------------
# When the LLM calls `wiki_get(slug, refresh=true)` on a stale article,
# Aperio regenerates the article in-place using THIS provider — *not* whichever
# model is in the user's chat. This keeps cheap/local refreshes off the cloud
# bill, and lets cloud-only users opt out simply by leaving this unset.
#
# Format: <provider>:<model>   (same as ROUNDTABLE_AGENTS)
# Supported providers: anthropic | ollama | deepseek | gemini
#
# Examples:
#   WIKI_REFRESH_PROVIDER=ollama:llama3.1       # free, local, requires Ollama
#   WIKI_REFRESH_PROVIDER=deepseek:deepseek-chat # cheap cloud, fast
#   WIKI_REFRESH_PROVIDER=anthropic:claude-haiku-4-5-20251001
#
# Leave unset → `wiki_get(refresh=true)` becomes a no-op and serves the stale body.
# ------------------------------------------------------------
WIKI_REFRESH_PROVIDER=ollama:llama3.1
#
# Only honored when WIKI_REFRESH_PROVIDER starts with "ollama:".
# If "true", Aperio will spawn `ollama serve` on the first refresh if it isn't
# already running. Note: if Ollama is up with a model already loaded into VRAM,
# the refresh model will still load on top — be mindful on RAM-constrained boxes.
WIKI_REFRESH_AUTOSTART_OLLAMA=true

# ── AI APIs ───────────────────────────────────────────────────
# ── Anthropic (cloud) ──────────────────────────────────────────
# Sign up at console.anthropic.com
# Model options: claude-sonnet-4-6, claude-opus-4-6, claude-opus-4-7
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxx-xxxx
ANTHROPIC_MODEL=claude-haiku-4-5-202510012
# ------------------------------------------------------------

# ── DeepSeek (cloud) ──────────────────────────────────────────
# ------------------------------------------------------------
# Sign up at platform.deepseek.com
# Model options: deepseek-v4-pro
# ------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_MODEL=deepseek-chat

# ── Google Gemini (cloud) ──────────────────────────────────────
# ------------------------------------------------------------
# Sign up at aistudio.google.com and generate an API key.
# Uses Google's OpenAI-compatible endpoint — no extra SDK needed.
# Model options: gemini-2.0-flash | gemini-2.5-pro | gemini-2.5-flash
# ------------------------------------------------------------
GEMINI_API_KEY=AIza-xxxx
GEMINI_MODEL=gemini-2.0-flash
# Thinking budget (tokens). 0 = disabled (default). Valid range when enabled: 512–24576.
# Use 512 for lite models, 8192+ for pro/flash on complex tasks.
# GEMINI_THINKING_BUDGET=0

# ── Ollama (local) ────────────────────────────────────────────
# ------------------------------------------------------------
# Install Ollama at ollama.ai, then: ollama pull qwen2.5:3b
# ------------------------------------------------------------
OLLAMA_VLM_MODEL=qwen2.5vl:7b
OLLAMA_MODEL=qwen2.5:3b
#OLLAMA_MODEL=llama3.1
#OLLAMA_MODEL=qwen3:4b
#OLLAMA_MODEL=gemma4:26b
OLLAMA_BASE_URL=http://localhost:11434
# ------------------------------------------------------------
# ── AI APIs ───────────────────────────────────────────────────

# ── Embeddings ────────────────────────────────────────────────
# ------------------------------------------------------------
# Options: 'transformers' | 'voyage'
# Default: 'transformers' (no external service required)
# ------------------------------------------------------------
# Option 1 — HuggingFace Transformers (default, fully local)
# - Downloads mixedbread-ai/mxbai-embed-large-v1 (ONNX, q8) on first run.
# - No daemon, no API key. Used by start:lite automatically.
EMBEDDING_PROVIDER=transformers
# ------------------------------------------------------------
# Option 2 — Voyage AI (cloud, free tier: 50M tokens/month)
# - Sign up at dash.voyageai.com
# ------------------------------------------------------------
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-xxxxx-xxxx
# ── Embeddings ────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
# ------------------------------------------------------------
# Idle shutdown timeout in seconds (default: 120 seconds = 2 minutes)
# - Server and Ollama shut down this many seconds after the last browser tab closes.
# Heartbeat interval in seconds (default: 60)
# - How often the frontend pings the server to signal a tab is still open.
# - Must be less than IDLE_TIMEOUT_SECONDS.
# ------------------------------------------------------------
PORT=31337
# Bind address. Default: 127.0.0.1 (loopback only — safe by default).
# Set to 0.0.0.0 only if you need LAN access and understand the risks.
# HOST=0.0.0.0
IDLE_TIMEOUT_SECONDS=180
HEARTBEAT_INTERVAL_SECONDS=120
SESSION_RETENTION_DAYS = 14
# ── Server ────────────────────────────────────────────────────