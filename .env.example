# ============================================================
# APERIO - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ============================================================
# / --- VECTOR STORE BACKEND ─────────────────────────────────
# / --- Options : 'postgres' | 'lancedb'
# / --- Default : auto-detect 
# / --- (uses Postgres if Docker is running, else LanceDB)
# ------------------------------------------------------------
DB_BACKEND=lancedb
# ============================================================

# ============================================================
# / --- APERIO LITE ────────────────────────────
# / --- LanceDB (non-technical users / no Docker)
# / --- Optional — defaults to ./.lancedb in the project root
# / --- npm install @lancedb/lancedb uuid
# ------------------------------------------------------------
LANCEDB_PATH=./.lancedb
# ============================================================

# ============================================================
# / --- APERIO DEVELOPER DATABASE ────────────────────────────
# / --- Postgres (power users / Docker)
# / --- When DB_BACKEND=postgres and Docker is running
# ------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret      # change this!
# ------------------------------------------------------------
# Connection string (used by MCP server + server.js)
# ------------------------------------------------------------
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio
# ============================================================

# ============================================================
# / --- PATH SAFETY ──────────────────────────────────────────
# / --- Restrict file operations to specific directories (comma-separated)
# / --- Defaults to your Aperio project directory if not set
# ------------------------------------------------------------
APERIO_ALLOWED_PATHS=/Users/yourname/projects,/Users/yourname/documents,/Users/yourname/Projects/aperio/ai-trash
# ============================================================

# ============================================================
# / --- AI PROVIDERS ───────────────────────────────────────────
# / --- Controls which AI backend Aperio uses.
# / --- Override at startup: npm run start:cloud / npm run start:local
# / --- If not set, defaults to "anthropic"
# ------------------------------------------------------------
#AI_PROVIDER=anthropic                # "anthropic" | "ollama"
#AI_PROVIDER=ollama
# ============================================================

# ============================================================
# / --- AI APIs ──────────────────────────────────────────────
# / --- Anthropic — get yours at console.anthropic.com
# / --- Other options: claude-sonnet-4-6, claude-opus-4-6, etc.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ============================================================

# ============================================================
# / --- OLLAMA (LOCAL AI) ────────────────────────────────────
# / --- Install Ollama at ollama.ai, then: ollama pull llama3.1
# / --- Other options: mistral, qwen2.5, gemma2, phi3, etc.
# ------------------------------------------------------------
OLLAMA_MODEL=qwen3
OLLAMA_BASE_URL=http://localhost:11434
# ============================================================

# ============================================================
# / --- EMBEDDINGS (DEFAULT OLLAMA) ───────────────────────────
# / --- ollama pull mxbai-embed-large
# ------------------------------------------------------------
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
# ------------------------------------------------------------
# Comment above two lines and uncomment below to use Voyage AI.
# Free tier at dash.voyageai.com (50M tokens/month)
# ------------------------------------------------------------
VOYAGE_API_KEY=pa-xxxxxx
# ============================================================

# ============================================================
# / --- SERVER ───────────────────────────────────────────────
# ------------------------------------------------------------
PORT=31337
# ============================================================