# ============================================================
# Aperio — Configuration
#
# Most people never edit this file. Just run `npm start` and the
# setup wizard in your browser fills it in for you.
#
# Appearance, voice responses, and similar preferences are set inside the
# app (the Settings panel) and saved to your database — not here. This file
# is only for plumbing: which AI to use, keys, ports, and the database.
#
# To configure by hand: copy this file to `.env` and set the few
# values in the ESSENTIALS block below. Everything past the STOP
# line is optional and already has sensible defaults.
#
# NEVER commit .env to git.
# ============================================================


# ─────────────────────────────────────────────────────────────
#  ESSENTIALS
# ─────────────────────────────────────────────────────────────

# Which AI backend to use:  anthropic | deepseek | gemini | ollama | claude-code
#   • anthropic / deepseek / gemini → cloud. Paste the matching API key below.
#   • ollama                        → free, runs on your own machine (no key).
#   • claude-code                   → uses your Claude Pro/Max subscription via
#                                     the Agent SDK. No API key needed — requires
#                                     `claude` CLI to be logged in (run `claude`
#                                     once to authenticate, or set
#                                     CLAUDE_CODE_OAUTH_TOKEN). Do NOT set
#                                     ANTHROPIC_API_KEY when using this provider
#                                     or it will bill your API account instead.
#                                     ANTHROPIC_MODEL still controls which model.
AI_PROVIDER=ollama

# --- CLOUD: fill in the key + model for the provider you chose above ---
# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# DeepSeek — platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Google Gemini — aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- LOCAL: if you chose ollama, set the model (install: ollama.ai) ---
# Pick by RAM: 8GB → qwen3:4b · 16GB → llama3.1:8b · 32GB+ → qwen3:14b
OLLAMA_MODEL=qwen3:4b

# Port the web app runs on.
PORT=31337


# ╶───────────────────────────────────────────────────────────╴
#  ✋  YOU CAN STOP HERE.
#      Everything below is optional and has working defaults.
#      Only change it if you know you need to.
# ╶───────────────────────────────────────────────────────────╴


# ── Vector store backend ──────────────────────────────────────
# 'postgres' (Docker required) | 'sqlite' (zero-config, default).
# Default: auto-detect — Postgres if Docker is running, else SQLite.
# DB_BACKEND=sqlite
# SQLITE_PATH=./sqlite/aperio.db    # where SQLite stores data (default shown)

# ── Postgres ──────────────────────────────────────────────────
# Only used when DB_BACKEND=postgres (or Docker is detected).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aperio
POSTGRES_USER=aperio
POSTGRES_PASSWORD=aperio_secret      # change this!
DATABASE_URL=postgresql://aperio:aperio_secret@localhost:5432/aperio

# ── File path safety ──────────────────────────────────────────
# SEED ONLY. These comma-separated absolute paths only populate the allowed-
# folders list on first run (when it doesn't yet exist in the DB). After that
# the list is edited in the UI (Settings → Allowed folders) and persisted in the
# database — these vars are ignored. When unset, the list defaults to the current
# working directory. The project dir + session scratch are always allowed.
# APERIO_ALLOWED_PATHS_TO_READ=/abs/path/one,/abs/path/two
# APERIO_ALLOWED_PATHS_TO_WRITE=/abs/path/one

# ── Shell execution (run_shell tool) ──────────────────────────
# Lets the model run a single allowlisted shell command (node, npm, git, ls,
# cat, grep, rg, find, head, tail, python3, soffice, pdftoppm) inside the
# session workspace — used for QA steps that need real binaries (e.g. pptx
# visual QA via soffice/pdftoppm, or grepping extracted text). Off by default.
# Commands run in the active session workspace; ; && || & < > backticks and
# $() are rejected, a single "|" pipe is allowed.
# APERIO_ENABLE_SHELL=1
#
# By default only cloud providers (Anthropic/Gemini/DeepSeek) get run_shell.
# Local Ollama models vary in capability and can thrash on tool calls, so they
# stay node-only unless you opt them in here.
# APERIO_SHELL_LOCAL=1

# ── Ollama (local) extras ─────────────────────────────────────
# Defaults shown — uncomment only to override.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_VLM_MODEL=qwen2.5vl:7b        # model used for image understanding
# OLLAMA_NUM_CTX=32768                 # context window (tokens) the app assumes
#   for its trim/cap math. The actual KV cache is sized by the SERVER's
#   OLLAMA_CONTEXT_LENGTH, not by anything sent over the /v1 chat API. When
#   Aperio starts Ollama for you it passes this value through as
#   OLLAMA_CONTEXT_LENGTH so both sides agree. If you run `ollama serve`
#   yourself, launch it with a matching OLLAMA_CONTEXT_LENGTH=<same value>.
#   Bigger is NOT free: an oversized window spills the model's KV cache from GPU
#   to CPU and generation crawls (e.g. 0.5 tok/s). Keep it within VRAM —
#   16384–32768 suits a 7–12B model; verify with `ollama ps` showing 100% GPU.
# OLLAMA_HOST=http://localhost:11434   # used by the auto start/stop helper;
#                                      # prefer OLLAMA_BASE_URL above — set this
#                                      # only if your Ollama host differs.
# Auto-pick the Ollama model from your free RAM (overrides OLLAMA_MODEL):
# CHECK_RAM=true

# ── Gemini thinking budget ────────────────────────────────────
# Tokens reserved for reasoning. 0 = off (default). Range when on: 512–24576.
# GEMINI_THINKING_BUDGET=0

# ── Round-table mode (two-agent cross-review) ─────────────────
# Boots a SECOND "verifier" agent. The Discuss toggle then routes a turn
# through: A answers → B reviews → A revises → … until both AGREE or the cap.
# Format: <provider>:<model>,<provider>:<model>  (first = answerer, second = reviewer)
# ROUNDTABLE_AGENTS=anthropic:claude-haiku-4-5-20251001,deepseek:deepseek-chat
# ROUNDTABLE_CHARACTERS="space-engineer,doctor"
# ROUNDTABLE_MAX_ROUNDS=3

# ── Wiki refresh provider (stale-article self-heal) ───────────
# When the LLM refreshes a stale wiki article, regenerate it with THIS
# provider instead of the chat model — keeps cheap/local refreshes off the
# cloud bill. Leave unset to disable (serves the stale body instead).
# Format: <provider>:<model>
# WIKI_REFRESH_PROVIDER=ollama:llama3.1
# Only honored for ollama: spawn `ollama serve` on first refresh if down.
WIKI_REFRESH_AUTOSTART_OLLAMA=true

# ── Embeddings ────────────────────────────────────────────────
# 'transformers' (default, fully local, no key) | 'voyage' (cloud).
# transformers downloads mixedbread-ai/mxbai-embed-large-v1 on first run.
# EMBEDDING_PROVIDER=transformers
# For Voyage (dash.voyageai.com, 50M tokens/month free):
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-xxxxx-xxxx
# Advanced: vector size + local model cache. EMBEDDING_DIMS must match your
# embedding model; changing it requires a fresh database.
# EMBEDDING_DIMS=1024
# TRANSFORMERS_CACHE=~/.cache/aperio/transformers

# ── GitHub integration ────────────────────────────────────────
# Personal access token for the github tools.
# fetch_github_issue (read): without a token 60 API requests/hour
# (unauthenticated, public repos only); with it 5000/hour + private repos.
# create_github_issue (write): a token is REQUIRED and needs `repo`
# (issues:write) scope — issue creation can't be anonymous.
# Generate at: github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Code graph (repo symbol index) ────────────────────────────
# Builds a symbol/reference index of the workspace so the model can
# navigate code. Off unless set to exactly 'on'.
# APERIO_CODEGRAPH=on
# APERIO_DOCGRAPH=on

# ── Background agents (scheduled, chat-less jobs) ──────────────
# Master switch for the background-agent scheduler. When 'on', enabled jobs in
# var/agents/jobs.json run on their interval, and POST /api/agents/:id/run works.
# Off (the default) means nothing fires — no need to edit jobs.json to disable.
# See docs/background-agents.md.
# APERIO_AGENT_JOBS=off

# ── Request timeouts (advanced) ───────────────────────────────
# Milliseconds. Raise if big local models or slow networks time out.
# DEEPSEEK_FETCH_TIMEOUT_MS=120000     # DeepSeek API request timeout
# OLLAMA_FETCH_TIMEOUT_MS=120000       # Ollama generate request timeout
# OLLAMA_HEALTH_TIMEOUT_MS=3000        # Ollama up/down health-check timeout

# ── Logging & diagnostics ─────────────────────────────────────
# How long to keep rotated log files (e.g. 7d, 30d, 14d).
# APERIO_LOG_RETENTION=30d
# Set to surface subprocess stderr that is hidden by default (debugging).
# DEBUG=1

# ── Server ────────────────────────────────────────────────────
# HOST default 127.0.0.1 (loopback only — safe). Set 0.0.0.0 for LAN access
# only if you understand the risks.
# HOST=0.0.0.0
# Server + Ollama shut down this many seconds after the last tab closes.
IDLE_TIMEOUT_SECONDS=180
# How often the browser pings to say a tab is still open (< IDLE_TIMEOUT).
HEARTBEAT_INTERVAL_SECONDS=120
# Days of chat history to keep.
SESSION_RETENTION_DAYS=14
