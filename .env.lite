# ── Server ────────────────────────────────────────
PORT=31337

# ── Ollama Models ─────────────────────────────────
# Override the hardware-recommended model by setting this.
# Leave blank to let the launcher auto-detect based on your RAM.
OLLAMA_MODEL=

# Embedding model — required, no auto-detection for this one
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Hardware thresholds → model mapping ───────────
# These let you tune the recommendation logic without recompiling.
# Format: RAM_GB:model_name, comma-separated, evaluated top-down.
MODEL_TIERS=36:deepseek-r1:7b,32:gemma4:27b,24:qwen3:14b,16:qwen3:8b,8:qwen2.5:3b